# ChikuMiku LearnVerse Web Client — Environment Variables
#
# Copy this file to .env.local for development.
# In production builds, these are set during the CI/CD pipeline.
#
# The API Gateway URL output by CDK stack (format: https://{restApiId}.execute-api.{region}.amazonaws.com/v1)
VITE_API_BASE_URL=http://localhost:3000/v1
