{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "shared/**/*.ts",
    "services/**/*.ts",
    "infra/**/*.ts",
    "clients/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
