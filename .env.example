# ──────────────────────────────────────────────────────────────────────────────
# ChikuMiku LearnVerse - Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for local development.
# For CI/CD, set these as GitHub Secrets or Vercel Environment Variables.

# ── AWS Configuration ─────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=ap-south-1

# ── Web Client (Vite) ────────────────────────────────────────────────────────
# API Gateway URL from CDK output (set after first deploy)
VITE_API_BASE_URL=http://localhost:3000/v1

# ── Third-Party API Keys (stored in AWS Secrets Manager for production) ──────
GOOGLE_VISION_API_KEY=
OPENAI_API_KEY=
GOOGLE_TTS_API_KEY=

# ── Vercel Deployment ─────────────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ── GitHub Actions (set as repository secrets) ────────────────────────────────
# AWS_DEPLOY_ROLE_ARN=arn:aws:iam::123456789012:role/GitHubActionsDeployRole
