{
  "name": "chikumiku-learnverse",
  "version": "0.1.0",
  "private": true,
  "description": "ChikuMiku LearnVerse - AI-powered learning platform",
  "workspaces": [
    "shared/types",
    "shared/validation",
    "infra",
    "services/auth",
    "services/content",
    "services/learning",
    "services/ai-gateway",
    "services/export",
    "clients/web",
    "clients/mobile"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "deploy:infra": "cd infra && npx cdk deploy --require-approval never --outputs-file cdk-outputs.json",
    "deploy:web": "vercel deploy --prod",
    "deploy": "npm run deploy:infra && npm run deploy:web"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "fake-indexeddb": "^6.0.0",
    "fast-check": "^4.8.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "5.4"
  }
}
