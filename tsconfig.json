{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "references": [
    { "path": "shared/types" },
    { "path": "shared/validation" },
    { "path": "shared/security" },
    { "path": "infra" },
    { "path": "services/auth" },
    { "path": "services/content" },
    { "path": "services/learning" },
    { "path": "services/ai-gateway" },
    { "path": "services/export" },
    { "path": "clients/web" },
    { "path": "clients/mobile" }
  ],
  "files": []
}
